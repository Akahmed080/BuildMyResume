{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Resume": {
      "title": "Resume",
      "description": "A resume created by a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner of the resume" },
        "name": { "type": "string" },
        "title": { "type": "string" },
        "data": { "type": "object", "description": "Full CV state object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "data"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/resumes/{resumeId}": {
      "schema": "Resume",
      "description": "Resume documents"
    }
  }
}
